usar todas de "motor_mazmorra.jasb"
clase Entidad
    entero id
    funcion reaccionar
fin_clase
clase Jugador extiende Entidad
    entero xp
fin_clase
Jugador g_heroe
funcion f1(entero e) retorna entero
    retornar e + 1
fin_funcion
principal
    funcion rf
    funcion dyn
    rf = f1
    g_heroe.reaccionar = rf
    dyn = g_heroe.reaccionar
    imprimir dyn(5)
fin_principal
