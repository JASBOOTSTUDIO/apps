# =============================================================================
# FUNCIONES AUXILIARES
# =============================================================================

funcion calcular_promedio(lista numeros) retorna flotante
    si lista_tamano(numeros) == 0 entonces
        retornar 0.0
    fin_si
    
    flotante suma = 0.0
    entero i = 0
    mientras i < lista_tamano(numeros) hacer
        flotante numero = lista_obtener(numeros, i)
        suma = suma + numero
        i = i + 1
    fin_mientras
    
    retornar suma / lista_tamano(numeros)
fin_funcion

funcion buscar_maximo(lista numeros) retorna flotante
    si lista_tamano(numeros) == 0 entonces
        retornar 0.0
    fin_si
    
    flotante maximo = lista_obtener(numeros, 0)
    entero i = 1
    mientras i < lista_tamano(numeros) hacer
        flotante numero = lista_obtener(numeros, i)
        si numero > maximo entonces
            maximo = numero
        fin_si
        i = i + 1
    fin_mientras
    
    retornar maximo
fin_funcion

funcion contar_elementos_texto(lista textos, texto buscar_texto) retorna entero
    entero contador = 0
    entero i = 0
    mientras i < lista_tamano(textos) hacer
        texto txt = lista_obtener(textos, i)
        si txt == buscar_texto entonces
            contador = contador + 1
        fin_si
        i = i + 1
    fin_mientras
    retornar contador
fin_funcion

