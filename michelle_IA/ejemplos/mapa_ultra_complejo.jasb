        lista_agregar(edades, mapa_obtener(empleado, "edad"))
        
        mapa habilidades = mapa_obtener(empleado, "habilidades")
        lista_agregar(niveles_experticia, mapa_obtener(habilidades, "nivel_experticia"))
        
        mapa evaluaciones = mapa_obtener(empleado, "evaluaciones")
        lista_agregar(puntajes_productividad, mapa_obtener(evaluaciones, "productividad"))
        
        i = i + 1
    fin_mientras
    
    imprimir "--- Estadísticas Salariales ---"
    flotante promedio_salarios = calcular_promedio(salarios)
    flotante promedio_salarios_totales = calcular_promedio(salarios_totales)
    flotante maximo_salario = buscar_maximo(salarios)
    imprimir "Salario base promedio: $" + promedio_salarios
    imprimir "Salario total promedio: $" + promedio_salarios_totales
    imprimir "Salario máximo: $" + maximo_salario
    imprimir ""
    
    imprimir "--- Estadísticas Demográficas ---"
    flotante promedio_edades = calcular_promedio(edades)
    flotante promedio_experticia = calcular_promedio(niveles_experticia)
    flotante promedio_productividad = calcular_promedio(puntajes_productividad)
    imprimir "Edad promedio: " + promedio_edades + " años"
    imprimir "Nivel de experticia promedio: " + promedio_experticia + "%"
    imprimir "Productividad promedio: " + promedio_productividad + "%"
    imprimir ""
    
    # =============================================================================
    # ANÁLISIS DE TECNOLOGÍAS
    # =============================================================================
    
    imprimir "=== ANÁLISIS DE TECNOLOGÍAS ==="
    lista todas_tecnologias = crear_lista()
    
    i = 0
    mientras i < lista_tamano(empleados) hacer
        mapa empleado = lista_obtener(empleados, i)
        mapa habilidades = mapa_obtener(empleado, "habilidades")
        lista tecnicas = mapa_obtener(habilidades, "tecnicas")
        
        entero j = 0
        mientras j < lista_tamano(tecnicas) hacer
            texto tech = lista_obtener(tecnicas, j)
            lista_agregar(todas_tecnologias, tech)
            j = j + 1
        fin_mientras
        
        i = i + 1
    fin_mientras
    
    imprimir "Total de tecnologías mencionadas: " + lista_tamano(todas_tecnologias)
    imprimir "Tecnologías únicas:"
    
    # Contar frecuencias (simplificado)
    imprimir "  JavaScript: " + contar_elementos_texto(todas_tecnologias, "JavaScript")
    imprimir "  Python: " + contar_elementos_texto(todas_tecnologias, "Python")
    imprimir "  React: " + contar_elementos_texto(todas_tecnologias, "React")
    imprimir "  Node.js: " + contar_elementos_texto(todas_tecnologias, "Node.js")
    imprimir "  Java: " + contar_elementos_texto(todas_tecnologias, "Java")
    imprimir "  Spring Boot: " + contar_elementos_texto(todas_tecnologias, "Spring Boot")
    imprimir ""
    
    # =============================================================================
    # CÁLCULOS FINANCIEROS COMPLEJOS
    # =============================================================================
    
    imprimir "=== CÁLCULOS FINANCIEROS ==="
    
    # Costo total de personal
    flotante costo_total_personal = 0.0
    i = 0
    mientras i < lista_tamano(empleados) hacer
        mapa empleado = lista_obtener(empleados, i)
        flotante salario_total = mapa_obtener(empleado, "salario_base") + mapa_obtener(empleado, "bono_anual")
        costo_total_personal = costo_total_personal + salario_total
        i = i + 1
    fin_mientras
    
    flotante presupuesto_departamento = mapa_obtener(departamento_tecnologia, "presupuesto_anual")
    flotante porcentaje_costo_personal = (costo_total_personal / presupuesto_departamento) * 100.0
    
    imprimir "Costo total de personal: $" + costo_total_personal
    imprimir "Presupuesto departamental: $" + presupuesto_departamento
    imprimir "Porcentaje del presupuesto usado en personal: " + porcentaje_costo_personal + "%"
    imprimir ""
    
    # Costo total de proyectos
    flotante costo_total_proyectos = 0.0
    i = 0
    mientras i < lista_tamano(proyectos) hacer
        mapa proyecto = lista_obtener(proyectos, i)
        costo_total_proyectos = costo_total_proyectos + mapa_obtener(proyecto, "presupuesto")
        i = i + 1
    fin_mientras
    
    flotante porcentaje_presupuesto_proyectos = (costo_total_proyectos / presupuesto_departamento) * 100.0
    imprimir "Costo total de proyectos: $" + costo_total_proyectos
    imprimir "Porcentaje del presupuesto usado en proyectos: " + porcentaje_presupuesto_proyectos + "%"
    imprimir ""
    
    # =============================================================================
    # CONCLUSIÓN Y RESUMEN
    # =============================================================================
    
    imprimir "=========================================================================="
    imprimir "RESUMEN DEL SISTEMA ULTRA COMPLEJO"
    imprimir "=========================================================================="
    imprimir "✅ Estructuras de datos anidadas (mapas dentro de mapas)"
    imprimir "✅ Listas complejas con múltiples tipos de datos"
    imprimir "✅ Funciones matemáticas avanzadas"
    imprimir "✅ Análisis estadístico completo"
    imprimir "✅ Cálculos financieros complejos"
    imprimir "✅ Bucles anidados y condicionales múltiples"
    imprimir "✅ Manipulación de strings y concatenación"
    imprimir "✅ Operaciones lógicas y booleanas"
    imprimir "✅ Acceso profundo a estructuras anidadas"
    imprimir "✅ Tipado estricto y conversión de tipos"
    imprimir "✅ Gestión de memoria y optimización"
