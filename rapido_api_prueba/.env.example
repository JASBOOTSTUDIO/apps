# Copia este archivo a .env y rellena (no subas .env al repositorio).
# CWD al ejecutar debe ser esta carpeta (run-jasb / VM desde rapido_api_prueba).

PORT=3000

# Bench / throughput: N procesos VM (puertos PORT, PORT+1, ...). Solo para comparar con Express cluster.
# RAPIDO_CLUSTER=8

# URI del pooler Supabase (usuario postgres.<ref>).
SUPABASE_DATABASE_URL=postgresql://postgres.TU_REF:tu_clave_bd@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# Anon o service_role desde Supabase → Project Settings → API
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REEMPLAZA

# Tabla expuesta en PostgREST para GET /api/supabase/muestra
SUPABASE_TABLA_PRUEBA=nombre_tabla

# Opcional: consulta PostgREST (por defecto ?select=*&limit=10)
# SUPABASE_CONSULTA=?select=*&limit=5
